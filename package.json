{
  "name": "@theluckystrike/webext-messaging",
  "version": "1.0.0",
  "description": "Promise-based typed message passing for Chrome extensions. Part of @zovo/webext.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build && npm run test"
  },
  "keywords": [
    "chrome-extension",
    "message-passing",
    "typed-messaging",
    "typescript",
    "webextension",
    "browser-extension",
    "manifest-v3",
    "chrome-runtime",
    "sendMessage",
    "promise",
    "async"
  ],
  "author": "theluckystrike",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theluckystrike/webext-messaging.git"
  },
  "homepage": "https://github.com/theluckystrike/webext-messaging#readme",
  "bugs": {
    "url": "https://github.com/theluckystrike/webext-messaging/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
